{
  "name": "noodlemat-dl",
  "author": "luna",
  "title": "NoodleMat Downloader",
  "description": "Download videos from NoodleMagazine and Mat6Tube.",
  "version": "1.0.1",
  "repository": {
    "url": "https://github.com/Cat-Ling/NoodleMat-DL"
  },
  "scripts": [
    {
      "event": "onResolve",
      "match": {
        "urls": [
          "*://noodlemagazine.com/*",
          "*://*.noodlemagazine.com/*",
          "*://mat6tube.com/*",
          "*://*.mat6tube.com/*"
        ]
      },
      "entry": "index.js"
    }
  ]
}
